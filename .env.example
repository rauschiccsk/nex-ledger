# NEX Ledger — Environment Configuration Example
# Copy to .env and customize

# Database connection (pg8000 driver — ICC standard)
# Internal Docker network uses port 5432, external access via 9181
DATABASE_URL=postgresql+pg8000://ledger:ledger@db:5432/nex_ledger
TEST_DATABASE_URL=postgresql+pg8000://ledger:ledger@db:5432/nex_ledger_test

# PostgreSQL credentials
POSTGRES_PASSWORD=ledger

# Application config
SECRET_KEY=change-this-in-production
APP_NAME=nex-ledger
PORT=9180
DEBUG=false
LOG_LEVEL=INFO
