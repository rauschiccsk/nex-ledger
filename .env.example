# NEX Ledger — Environment Configuration Example
# Copy to .env and customize

DATABASE_URL=postgresql+pg8000://ledger:ledger@localhost:9181/nex_ledger
TEST_DATABASE_URL=postgresql+pg8000://ledger:ledger@localhost:9181/nex_ledger_test
SECRET_KEY=change-this-in-production
APP_NAME=nex-ledger
PORT=9180
DEBUG=false
LOG_LEVEL=INFO
